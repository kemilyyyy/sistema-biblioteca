@model sistema_biblioteca.Models.Usuario

@{
    ViewData["Title"] = "Detalhes do Usuário";
}

<h2>Detalhes</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Nome</dt>
            <dd class="col-sm-9">@Model.Nome</dd>

            <dt class="col-sm-3">CPF</dt>
            <dd class="col-sm-9">@Model.Cpf</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Telefone</dt>
            <dd class="col-sm-9">@Model.Telefone</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Data Cadastro</dt>
            <dd class="col-sm-9">@(Model.DataCadastro?.ToString("yyyy-MM-dd"))</dd>
        </dl>
        <a class="btn btn-secondary" asp-action="Index">Voltar</a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.IdUsuario">Editar</a>
    </div>
</div>
