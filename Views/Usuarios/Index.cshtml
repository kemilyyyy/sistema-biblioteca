@model IEnumerable<sistema_biblioteca.Models.Usuario>

@{
    ViewData["Title"] = "Usuários";
}

<h2>Usuários</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Novo Usuário</a>
</p>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nome</th>
                <th>CPF</th>
                <th>Email</th>
                <th>Telefone</th>
                <th>Status</th>
                <th>Data Cadastro</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nome</td>
                <td>@item.Cpf</td>
                <td>@item.Email</td>
                <td>@item.Telefone</td>
                <td>@item.Status</td>
                <td>@(item.DataCadastro?.ToString("yyyy-MM-dd"))</td>
                <td>
                    <a class="btn btn-sm btn-secondary" asp-action="Details" asp-route-id="@item.IdUsuario">Detalhes</a>
                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.IdUsuario">Editar</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.IdUsuario">Excluir</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
