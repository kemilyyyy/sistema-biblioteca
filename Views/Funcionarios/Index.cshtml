@model IEnumerable<sistema_biblioteca.Models.Funcionario>

@{
    ViewData["Title"] = "Funcionários";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Funcionários</h2>
    <a class="btn btn-primary" asp-action="Create">Novo Funcionário</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="table-responsive">
<table class="table table-hover">
    <thead class="table-light">
        <tr>
            <th>Nome</th>
            <th>Cargo</th>
            <th>Username</th>
            <th>Role</th>
            <th>Email</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Nome</td>
            <td>@item.Cargo</td>
            <td>@item.Username</td>
            <td>@item.Role</td>
            <td>@item.Email</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Details" asp-route-id="@item.Id">Detalhes</a>
                <a class="btn btn-sm btn-outline-primary me-1" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
