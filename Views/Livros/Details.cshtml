@model sistema_biblioteca.Models.Livro

@{
    ViewData["Title"] = "Detalhes do Livro";
}

<div class="card">
    <div class="card-body">
        <h3 class="card-title">@Model.Titulo</h3>
        <h6 class="text-muted">@Model.Autor</h6>

        <dl class="row mt-3">
            <dt class="col-sm-3">ISBN</dt>
            <dd class="col-sm-9">@Model.ISBN</dd>

            <dt class="col-sm-3">Gênero</dt>
            <dd class="col-sm-9">@Model.Genero</dd>

            <dt class="col-sm-3">Publicação</dt>
            <dd class="col-sm-9">@Model.DataPublicacao?.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">Estoque</dt>
            <dd class="col-sm-9">@Model.QtdEstoque</dd>

            <dt class="col-sm-3">Ativo</dt>
            <dd class="col-sm-9">@(Model.Ativo ? "Sim" : "Não")</dd>
        </dl>

        <a class="btn btn-secondary" asp-action="Index">Voltar</a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Editar</a>
    </div>
</div>
