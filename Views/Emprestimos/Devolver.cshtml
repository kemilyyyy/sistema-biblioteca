@model sistema_biblioteca.Models.Emprestimo

@{
    ViewData["Title"] = "Devolução";
}

<h2>Registrar Devolução</h2>

<div class="card">
    <div class="card-body">
        <h5>@Model.Livro?.Titulo</h5>
        <p class="text-muted">Cliente: @Model.Cliente?.Nome</p>

        <p>Data de retirada: @Model.DataRetirada.ToString("yyyy-MM-dd")</p>
        <p>Previsão de devolução: @Model.DataPrevisaoDevolucao.ToString("yyyy-MM-dd")</p>

        <form asp-action="DevolverConfirmado" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="mt-3">
                <button type="submit" class="btn btn-success">Confirmar Devolução</button>
                <a class="btn btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>
