@model IEnumerable<sistema_biblioteca.Models.Emprestimo>

@{
    ViewData["Title"] = "Empréstimos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Empréstimos</h2>
    <a class="btn btn-primary" asp-action="Create">Novo Empréstimo</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="table-responsive">
<table class="table table-hover">
    <thead class="table-light">
        <tr>
            <th>Cliente</th>
            <th>Livro</th>
            <th>Retirada</th>
            <th>Prev.Devolução</th>
            <th>Devolução</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Cliente?.Nome</td>
            <td>@item.Livro?.Titulo</td>
            <td>@item.DataRetirada.ToString("yyyy-MM-dd")</td>
            <td>@item.DataPrevisaoDevolucao.ToString("yyyy-MM-dd")</td>
            <td>@(item.DataDevolucao?.ToString("yyyy-MM-dd") ?? "-")</td>
            <td>
                @if (item.DataDevolucao == null)
                {
                    if (item.EstaAtrasado)
                    {
                        <span class="badge bg-danger">Atrasado (@item.DiasAtraso dias)</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Ativo</span>
                    }
                }
                else
                {
                    <span class="badge bg-secondary">Devolvido</span>
                }
            </td>
            <td>
                <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Details" asp-route-id="@item.Id">Detalhes</a>
                @if (item.DataDevolucao == null)
                {
                    <a class="btn btn-sm btn-outline-success" asp-action="Devolver" asp-route-id="@item.Id">Devolver</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
