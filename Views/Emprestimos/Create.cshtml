@model sistema_biblioteca.Models.Emprestimo

@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Novo Empréstimo";
}

<h2>Novo Empréstimo</h2>

<form asp-action="Create" method="post">
    <div class="card">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Cliente</label>
                <select asp-for="ClienteId" asp-items="@(ViewBag.Clientes as SelectList)" class="form-select"></select>
                <span asp-validation-for="ClienteId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Livro</label>
                <select asp-for="LivroId" asp-items="@(ViewBag.Livros as SelectList)" class="form-select"></select>
                <span asp-validation-for="LivroId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Atendente</label>
                <select asp-for="FuncionarioId" asp-items="@(ViewBag.Funcionarios as SelectList)" class="form-select"></select>
                <span asp-validation-for="FuncionarioId" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" type="submit">Registrar Empréstimo</button>
        <a class="btn btn-secondary" asp-action="Index">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
