@model IEnumerable<sistema_biblioteca.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Clientes</h2>
    <a class="btn btn-primary" asp-action="Create">Novo Cliente</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="table-responsive">
<table class="table table-hover">
    <thead class="table-light">
        <tr>
            <th>Nome</th>
            <th>Matrícula</th>
            <th>Telefone</th>
            <th>E-mail</th>
            <th>Bloqueado</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Nome</td>
            <td>@item.Matricula</td>
            <td>@item.Telefone</td>
            <td>@item.Email</td>
            <td>@(item.Bloqueado ? "Sim" : "Não")</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Details" asp-route-id="@item.Id">Detalhes</a>
                <a class="btn btn-sm btn-outline-primary me-1" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
