@model sistema_biblioteca.Models.Cliente

@{
    ViewData["Title"] = "Detalhes do Cliente";
}

<div class="card">
    <div class="card-body">
        <h3>@Model.Nome</h3>
        <dl class="row mt-3">
            <dt class="col-sm-3">Matrícula</dt>
            <dd class="col-sm-9">@Model.Matricula</dd>

            <dt class="col-sm-3">CPF</dt>
            <dd class="col-sm-9">@Model.CPF</dd>

            <dt class="col-sm-3">E-mail</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Telefone</dt>
            <dd class="col-sm-9">@Model.Telefone</dd>

            <dt class="col-sm-3">Logradouro</dt>
            <dd class="col-sm-9">@Model.Logradouro</dd>

            <dt class="col-sm-3">Bloqueado</dt>
            <dd class="col-sm-9">@(Model.Bloqueado ? "Sim" : "Não")</dd>
        </dl>

        <a class="btn btn-secondary" asp-action="Index">Voltar</a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Editar</a>
    </div>
</div>
