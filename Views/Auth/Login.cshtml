@model sistema_biblioteca.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login do sistema";
}

<div class="row justify-content-center py-5">
    <div class="col-lg-5 col-md-7">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10 text-primary mb-3" style="width:3.5rem;height:3.5rem;">
                        <i class="bi bi-book-half fs-3"></i>
                    </div>
                    <h1 class="h3 mb-1">Acesso ao sistema</h1>
                    <p class="text-muted mb-0">Escolha o perfil e entre com e-mail e senha.</p>
                </div>

                <div class="alert alert-light border mb-4">
                    <p class="mb-2 fw-semibold">Credenciais de demonstração</p>
                    <div class="small text-muted">
                        <div><strong>E-mail atendente:</strong> atendente@biblioteca.com</div>
                        <div><strong>Senha atendente:</strong> atendente123</div>
                        <div><strong>E-mail bibliotecário:</strong> bibliotecario@biblioteca.com</div>
                        <div><strong>Senha bibliotecário:</strong> bibliotecario123</div>
                    </div>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control form-control-lg" placeholder="atendente@biblioteca.com" autocomplete="username" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Senha" class="form-label"></label>
                        <input asp-for="Senha" class="form-control form-control-lg" placeholder="Digite sua senha" autocomplete="current-password" />
                        <span asp-validation-for="Senha" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Entrar
                    </button>
                </form>

                <div class="row g-3 mt-4">
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                            <h2 class="h6 mb-2"><i class="bi bi-person-badge me-2 text-primary"></i>Atendente</h2>
                            <p class="small text-muted mb-0">Operação diária, empréstimos, devoluções e cadastros básicos de usuários.</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                            <h2 class="h6 mb-2"><i class="bi bi-shield-check me-2 text-success"></i>Bibliotecário</h2>
                            <p class="small text-muted mb-0">Acesso completo, incluindo livros, inativação e relatórios de gestão.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
